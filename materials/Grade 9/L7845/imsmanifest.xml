        <tlf:keylearningobjective>
          <tlf:langstring xml:lang="en">Students apply the unit circle definitions of the cosine function.</tlf:langstring>
        </tlf:keylearningobjective>
        <tlf:keylearningobjective>
          <tlf:langstring xml:lang="en">Students interpret a graph of cos &#xd8;, from 0&#xb0; to 360&#xb0;.</tlf:langstring>
        </tlf:keylearningobjective>
        <tlf:keylearningobjective>
          <tlf:langstring xml:lang="en">Students identify patterns and symmetry of the cosine function.</tlf:langstring>
        </tlf:keylearningobjective>
        <tlf:educationalvalue>
          <tlf:langstring xml:lang="en">Enables students to compare and understand the key features of the cosine function (from 0&#xb0; to 360&#xb0;).</tlf:langstring>
        </tlf:educationalvalue>
        <tlf:educationalvalue>
          <tlf:langstring xml:lang="en">Provides an interactive unit circle tool to ensure students work with general definitions of the cosine function, connected to the right-angled triangle definition.</tlf:langstring>
        </tlf:educationalvalue>
        <tlf:educationalvalue>
          <tlf:langstring xml:lang="en">Includes challenges that highlight the symmetry and patterns of the cosine function.</tlf:langstring>
        </tlf:educationalvalue>
        <tlf:educationalvalue>
          <tlf:langstring xml:lang="en">Contains associations with real-world periodic phenomena that are modelled with trigonometric functions.</tlf:langstring>
        </tlf:educationalvalue>
